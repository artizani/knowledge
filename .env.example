# Knowledge API - example environment configuration.
# Copy to `.env` for local development. In AWS these come from Secrets Manager.

# --- Database -------------------------------------------------------------
# Local development can use SQLite; production uses the Supabase pooler.
# DATABASE_URL=sqlite+pysqlite:///./knowledge_local.db
# DATABASE_URL=postgresql+psycopg2://postgres:<password>@<project>.pooler.supabase.com:6543/postgres

# --- Authentication -------------------------------------------------------
# A static bearer token for internal use...
API_TOKEN=change-me-local-token
# ...and/or an HS256 JWT secret (e.g. Auth.js). Either is accepted.
# JWT_SECRET=your-jwt-signing-secret
# JWT_AUDIENCE=knowledge-api
# JWT_ISSUER=https://your-issuer.example.com

# Require a token on writes (default true). Reads are open unless enabled.
AUTH_REQUIRED=true
# REQUIRE_AUTH_FOR_READS=false

# --- Observability --------------------------------------------------------
LOG_LEVEL=INFO

# --- AWS (runtime only) ---------------------------------------------------
# SECRET_ARN=arn:aws:secretsmanager:...:secret:knowledge-api/config-XXXXXX
# AWS_REGION=eu-west-1

# --- Query limits ---------------------------------------------------------
# DEFAULT_LIST_LIMIT=50
# MAX_LIST_LIMIT=200
